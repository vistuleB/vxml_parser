<> html
    <> head
        <> link
            rel icon
            href logo.png
        <> title
            <>
                "Sample HTML Page"
        <> link
            rel stylesheet
            href css/main.css
        <> meta
            http-equiv Content-Type
            content text/html;charset=utf-8;
    <> body
        <> div
            id container
            <> h1
                <>
                    "Big H1 title"
            <> p
                <>
                    "Hello "
                <> i
                    <>
                        "dear user"
                <>
                    ", this is our"
                    "first "
                <> b
                    <>
                        "paragraph"
                <>
                    "."
            <> p
                <>
                    "This shall be "
                    "a second paragraph."
